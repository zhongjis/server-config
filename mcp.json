{
  "mcpServers": {
    "context7": {
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "${CONTEXT7_API_KEY}"
      },
      "directTools": true,
      "lifecycle": "lazy"
    },
    "nixos": {
      "command": "nix",
      "args": ["run", "github:utensils/mcp-nixos", "--"],
      "directTools": true,
      "lifecycle": "lazy"
    },
    "flux": {
      "command": "nix",
      "args": ["run", "nixpkgs#fluxcd-operator-mcp", "--", "serve", "--read-only", "--mask-secrets"],
      "directTools": true,
      "lifecycle": "lazy"
    }
  }
}
